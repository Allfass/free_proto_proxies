# Данные приложения с https://my.telegram.org
API_ID=123456
API_HASH=your_api_hash

# Сессия пользователя для проверки (генерируется отдельным скриптом, см. README)
USER_SESSION=your_string_session

# Токен бота от @BotFather
BOT_TOKEN=123:ABC

# Чат/канал, куда публиковать прокси (например, -1001234567890)
TARGET_CHAT_ID=-1001234567890

# Источник прокси
SOURCE_URL=https://raw.githubusercontent.com/SoliSpirit/mtproto/master/all_proxies.txt

# Файл с состоянием
STATE_FILE=state.json